<&|/Widgets/TitleBox, title => loc('Kanban')&>

<%perl>
# jQuery 3.6 is already loaded by RT 6 — do NOT load jQuery 1.9.1 again.
# jQuery UI is loaded via RT->AddJavaScript('jquery-ui.min.js') in KANBAN.pm.
</%perl>

<script>
// Wrap everything in an IIFE so that let/const variables are function-scoped.
// This prevents "Identifier already declared" errors when HTMX re-executes
// this script during history navigation or partial page swaps.
(function() {
// RT 6 loads jQuery in noConflict mode — $ is not jQuery globally.
var $ = jQuery;

//////////////////////GLOBAL VARIABLES
  let ticketCache = {};
  let ticketViewCache = {};
  let autocompleteValues = [];
  let hidden = [];
  let filter = {};
  let Columns = [];
  let advancedPriority = false;
  const currentUser = "<% $session{'CurrentUser'}->Name %>";
  let config = "";

//////////////////////TEMPLATES/////////////////////////
  const templateDropdownLink = doT.template(`
    <div id="DropdownLink" class="kanban-dropdown">
      <div class="fw-semibold small mb-2 text-primary border-bottom pb-1">Link ticket</div>
      <label for="dependsOn">Depends on</label>
      <input id="dependsOn" class="auto" type="text" placeholder="Ticket# ...">
      <label for="DependedOnBy">Depended on by</label>
      <input id="DependedOnBy" class="auto" placeholder="Ticket# ...">
      <label for="RefersTo">Refers to</label>
      <input id="RefersTo" class="auto" placeholder="Ticket# ...">
      <label for="ReferredToBy">Referred to by</label>
      <input id="ReferredToBy" class="auto" placeholder="Ticket# ...">
      <label for="HasMember">Children</label>
      <input id="HasMember" class="auto" placeholder="Ticket# ...">
      <label for="MemberOf">Parents</label>
      <input id="MemberOf" class="auto" placeholder="Ticket# ...">
      <div class="text-muted" style="font-size:0.7rem;margin-top:0.25rem">Press Enter to save · Esc to close</div>
    </div>
    `);

  const templateDropdownMerge = doT.template(`
    <div id="DropdownMerge" class="kanban-dropdown">
      <div class="fw-semibold small mb-2 text-danger border-bottom pb-1">Merge ticket</div>
      <label for="merge">Merge into ticket#</label>
      <input id="merge" class="auto" placeholder="Ticket# ...">
      <div class="text-muted" style="font-size:0.7rem;margin-top:0.25rem">Press Enter to merge · Esc to close</div>
    </div>
    `);

  const templateTicket = doT.template(`
    <li id="{{=it.id}}" class="ticket">
      <div class="card shadow-sm border-0">
        <div class="ticket-id-bar">
          <span class="badge bg-secondary">#{{=it.id}}</span>
          <div class="ticket-actions">
% if (!$readOnly){
            <button onclick="showDropMerge(this, '{{=it.id}}')" class="btn btn-sm btn-outline-secondary">merge</button>
            <button onclick="showDropLink(this, '{{=it.id}}')"  class="btn btn-sm btn-outline-primary">link</button>
%}
          </div>
        </div>
        <div class="ticket-owner-bar" style="background-color:{{=it.Color}}; color:{{=it.ColorInverse}};">
% if ($readOnly){
          <span class="fw-semibold">{{=it.Owner}}</span>
%}else{
          <select onchange="setOwner('{{=it.id}}', this)" title="Owner">
            <option value="Nobody">Nobody</option>
% while ( my $user = $users->Next ) {
            <option value="<% $user->Name %>" {{? it.Owner == "<% $user->Name %>"}}selected="selected"{{?}}><% $user->Name %></option>
%}
          </select>
%}
        </div>
        <div class="ticket-subject" style="background-color:{{=it.ColorBright}};">
          <a href="<%RT->Config->Get('WebPath')%>/Ticket/Display.html?id={{=it.id}}">{{=it.Subject}}</a>
        </div>
        <div class="ticket-footer">
          <span class="estimate">
% if ($readOnly){
            {{=it.hour}}h&nbsp;{{=it.minute}}m
%}else{
            <input type="number" onchange="saveTimeHours('{{=it.id}}', this)"   min="0"           class="numedit" value="{{=it.hour}}">h
            <input type="number" onchange="saveTimeMinutes('{{=it.id}}', this)" min="0" max="59"  class="numedit" value="{{=it.minute}}">m
%}
          </span>
          <span class="text-truncate ms-2" title="Creator: {{=it.Creator}}">{{=it.Creator}}</span>
        </div>
      </div>
    </li>`);

  const templateColumn = doT.template(`
      <div id="div{{=it.Id}}" class="column">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-header d-flex align-items-center justify-content-between">
            <h6 class="mb-0">{{=it.Name}}</h6>
            <span class="badge bg-white text-primary rounded-pill lane-count">0</span>
          </div>
          <ul id="{{=it.Id}}" class="wipDrop tasks ui-sortable"></ul>
        </div>
      </div>
    `);
////////////////END TEMPLATES////////////////////


/////////////////USERINPUT FOR SINGLE TICKETS///////////

  function saveTimeMinutes(userID, obj) {
      const ticket = ticketCache[userID];
      ticket['minute'] = parseInt($(obj).val());
      saveTicketTime(ticket);
  }

  function saveTimeHours(userID, obj) {
      const ticket = ticketCache[userID];
      ticket['hour'] = parseInt($(obj).val());
      saveTicketTime(ticket);
  }

  let timer = undefined;
  let timerTicket = undefined;

  function saveTicketTime(ticket) {
    ticket['TimeEstimated'] = ticket['minute'] + 60 * ticket['hour'];

    const save = function() {
      saveTicket(timerTicket['id'], {TimeEstimated: timerTicket['TimeEstimated']});
      timerTicket = undefined;
    };
    if (timer !== undefined) {
      clearTimeout(timer);
    }
    timer = setTimeout(save, 1000);
    if (timerTicket !== undefined && timerTicket !== ticket) {
      saveTicket(timerTicket['id'], {TimeEstimated: timerTicket['TimeEstimated']});
    }
    timerTicket = ticket;
  }

  function setOwner(id, obj) {
      const ticket = ticketCache[id];
      ticket['Owner'] = obj.options[obj.selectedIndex].value;
      ticket["Color"] = "#" + intToRGB(parseInt("0x" + md5(ticket["Owner"]).substring(0, 8)));
      ticket["ColorInverse"] = invertColor(ticket["Color"]);

      $(obj).css({'background-color': ticket["Color"], 'color': ticket["ColorInverse"]});

      saveTicket(id, {Owner: obj.options[obj.selectedIndex].value});
  }

  const SHIFT = 135;

  function updatePS(id, LaneObject, Lane, shift, laneID) {
    const ticket = ticketCache[id];
    ticket.lane = laneID;
    const ticketField = $("#" + id);
    const nextTicket = ticketCache[ticketField.next().attr('id')];

    if (advancedPriority) {
      const prevTicket = ticketCache[ticketField.prev().attr('id')];
      let nextPriority = -2147483648;
      let prevPriority = 2147483647;

      if (typeof nextTicket !== 'undefined') {
          nextPriority = parseInt(nextTicket['Priority']);
      }
      if (typeof prevTicket !== 'undefined') {
          prevPriority = parseInt(prevTicket['Priority']);
      }
      const divPriority = prevPriority - nextPriority;
      if (divPriority <= 1) {
        if ((shift === '' && nextPriority > 0) || shift === 'bottom') {
          ticket['Priority'] = prevPriority - SHIFT;
          updatePS(nextTicket['id'], LaneObject, Lane, 'bottom', laneID);
        } else {
          ticket['Priority'] = nextPriority + SHIFT;
          updatePS(prevTicket['id'], LaneObject, Lane, 'top', laneID);
        }
      } else {
        ticket['Priority'] = nextPriority + Math.round(divPriority / 2);
      }
    } else if (typeof nextTicket !== 'undefined') {
      if (ticket['Priority'] <= parseInt(nextTicket['Priority'])) {
        ticket['Priority'] = parseInt(nextTicket['Priority']) + 1;
      }
    }

    const change = LaneObject.Change;
    const keys = Object.keys(change);
    const fields = {Priority: ticket['Priority']};

    if ("CallOnEnter" in LaneObject) {
      const f = new Function("ticket", getQuery(LaneObject.CallOnEnter, LaneObject.timeOffSet));
      const update = f(ticket);
      for (let i = 0; i < update.length; i++) {
        fields[update[i]] = ticket[update[i]];
      }
    }

    for (let i = 0; i < keys.length; i++) {
      ticket[keys[i]] = getQuery(change[keys[i]]);
      fields[keys[i]] = getQuery(change[keys[i]], Columns[laneID].timeOffSet);
    }

    saveTicket(id, fields);
    if (!advancedPriority) {
      updateTicketPosition(ticket);
    }
  }


//DROPDOWN

  $(document).on('keyup', function(e) {
    if (e.keyCode === 27) {
      closeAllDropDown();
    }
  });

  let linkDropDownOpen = false;

  function closeAllDropDown() {
    $("#DropdownMerge").remove();
    $("#DropdownLink").remove();
  }

  function showDropLink(btn, id) {
    if ($(btn).next().length === 0 || !linkDropDownOpen) {
      linkDropDownOpen = true;
      closeAllDropDown();
      const tropdown = templateDropdownLink();
      $(btn).after(tropdown);
      $('#dependsOn').focus();
      $(".auto").on("keydown", function(event) {
        if (event !== undefined) {
          if (event.keyCode === 13) {
            if (!$(this).autocomplete("instance").menu.active) {
              link(id, this.id, split($(this).val().trim()));
              closeAllDropDown();
            }
          } else if (event.keyCode === $.ui.keyCode.TAB &&
              $(this).autocomplete("instance").menu.active) {
            event.preventDefault();
          }
        }
      }).autocomplete({
        minLength: 0,
        delay: 0,
        source: function(request, response) {
          let results = $.ui.autocomplete.filter(autocompleteValues, extractLast(request.term));
          const allValues = split(request.term);
          allValues.splice(allValues.length - 1, 1);
          results = results.filter(function(el) {
            if (el['value'] === id) return false;
            return allValues.every(function(input) {
              return el['value'] !== input;
            });
          });
          response(results.slice(0, 10));
        },
        focus: function() { return false; },
        select: function(event, ui) {
          const terms = split(this.value);
          terms.pop();
          terms.push(ui.item.value);
          terms.push("");
          this.value = terms.join(" ");
          return false;
        }
      });
    } else {
      closeAllDropDown();
    }
    autocompleteValues.sort(function(a, b) { return a['value'] - b['value']; });
  }

  function showDropMerge(btn, id) {
    if ($(btn).next().next().length === 0 || linkDropDownOpen) {
      closeAllDropDown();
      linkDropDownOpen = false;
      const tropdown = templateDropdownMerge();
      $(btn).parent().append(tropdown);
      $('#merge').focus();
      $(".auto").on("keydown", function(event) {
        if (event.keyCode === 13) {
          if (!$(this).autocomplete("instance").menu.active) {
            merge(id, split($(this).val().trim()));
            closeAllDropDown();
          }
          return;
        }
        if (event.keyCode === $.ui.keyCode.TAB &&
            $(this).autocomplete("instance").menu.active) {
          event.preventDefault();
        }
      }).autocomplete({
        minLength: 0,
        delay: 0,
        source: function(request, response) {
          let results = $.ui.autocomplete.filter(autocompleteValues, request.term);
          results = results.filter(function(el) {
            return el['value'] !== id;
          });
          response(results.slice(0, 10));
        },
        focus: function() { return false; },
        select: function(event, ui) {
          const terms = split(this.value);
          terms.pop();
          terms.push(ui.item.value);
          terms.push("");
          this.value = terms.join(" ");
          return false;
        }
      });
    } else {
      closeAllDropDown();
    }
    autocompleteValues.sort(function(a, b) { return a['value'] - b['value']; });
  }

//////////////////USERINPUT FOR KANBAN //////////////
  let fullscreen = false;

  function toggleFullScreen() {
    const main = $('#main');
    const nav = $('header.navbar, nav.navbar, #rt-header, #page-navigation, #main-navigation, .rt-header, #header');
    fullscreen = !fullscreen;
    if (fullscreen) {
      main.addClass('kanban-fullscreen');
      $('body').css('overflow', 'hidden');
      nav.hide();
    } else {
      main.removeClass('kanban-fullscreen');
      $('body').css('overflow', '');
      nav.show();
    }
  }

//FILTERS
  function testFilter(ticket) {
    for (let i = 0; i < filters.length; i++) {
      const attrName = filters[i];
      const match = function(word) {
        return RegExp(word).test(ticket[attrName]);
      };
      if (filterWords[attrName] && filterWords[attrName].length > 0 && !filterWords[attrName].some(match)) {
        return false;
      }
    }
    return true;
  }

  let filters = [];
  let filterWords = {};

  function setFilter(name, input) {
    const newVal = $(input).val().trim();
    const newWords = newVal.split(/\s+/).filter(Boolean);
    filter[name] = newVal;
    filters = Object.keys(filter);
    filterWords[name] = newWords;

    const newHidden = [];
    $('.ticket').each(function() {
      const id = $(this).attr('id');
      const ticket = ticketCache[id];
      if (!testFilter(ticket)) {
        ticketViewCache[id] = this;
        $(this).remove();
        newHidden.push(id);
      }
    });
    hidden.forEach(function(id) {
      const ticket = ticketCache[id];
      if (testFilter(ticket)) {
        insertTicket(ticket, ticketViewCache[id]);
      } else {
        newHidden.push(id);
      }
    });
    hidden = newHidden;
  }

  function clearFilter() {
    $('.filter').val('');
    $('.filter').trigger('keyup');
    filters = {};
  }

//////////////////////UTIL//////////////////////////
  const ticketFields = [/id/g, /Queue/g, /Owner/g, /Creator/g, /Subject/g, /Status/g, /Priority/g, /InitialPriority/g, /FinalPriority/g, /Requestors/g, /Created/g, /Starts/g, /Started/g, /Due/g, /Resolved/g, /Told/g, /LastUpdated/g, /TimeEstimated/g, /TimeWorked/g, /TimeLeft/g, /Cc/g, /AdminCc/g];
  const ticketFieldsString = ['id', 'Queue', 'Owner', 'Creator', 'Subject', 'Status', 'Priority', 'InitialPriority', 'FinalPriority', 'Requestors', 'Created', 'Starts', 'Started', 'Due', 'Resolved', 'Told', 'LastUpdated', 'TimeEstimated', 'TimeWorked', 'TimeLeft', 'Cc', 'AdminCc'];

  function toFunction(query) {
    let funString = query.replace(/AND/g, '&&');
    funString = funString.replace(/OR/g, '||');
    funString = funString.replace(/NOT/g, '!');
    funString = funString.replace(/=/g, '==');
    funString = funString.replace(/<==/g, '<=');
    funString = funString.replace(/>==/g, '>=');
    funString = funString.replace(/<>/g, '!=');
    for (let i = 0; i < ticketFields.length; i++) {
      funString = funString.replace(ticketFields[i], 'ticket.' + ticketFieldsString[i]);
    }
    funString = 'return ' + funString;
    return new Function('ticket', funString);
  }

  function binarylower(obj, f, m, l, u) {
    if (l <= u) {
      const mid = Math.floor((l + u) / 2);
      if (obj[mid] === undefined) return l;
      if (m > f(obj[mid])) return binarylower(obj, f, m, l, mid - 1);
      else return binarylower(obj, f, m, mid + 1, u);
    } else {
      return l;
    }
  }

  function needsUpdate(a, b) {
    if (a === undefined || b === undefined) return true;
    const props = ["Queue", "Subject", "Owner", "Creator", "TimeEstimated", "Status", "Priority", "minute", "hour"];
    for (let i = 0; i < props.length; i++) {
      if (a[props[i]] !== b[props[i]]) return true;
    }
    return false;
  }

  function getQuery(string, timeOffSet) {
    const d = new Date();
    d.setDate(d.getDate() - (timeOffSet || 0));
    const date = d.getFullYear() + "-" + (d.getMonth() + 1) + "-" + d.getDate();
    const it = {Date: date, CurrentUser: currentUser};
    return doT.template(string)(it);
  }

  function deleteTicket(ticket) {
    if (ticket !== undefined) {
      const id = ticket['id'];
      console.log('delete: ' + id);
      let index = -1;
      for (let i = 0; i < autocompleteValues.length; i++) {
        if (autocompleteValues[i]['value'] === id) {
          index = i;
          break;
        }
      }
      if (index > -1) autocompleteValues.splice(index, 1);
      const lane = ticket.lane;
      delete ticketCache[id];
      delete ticketViewCache[id];
      $("#" + id).remove();
      if (lane !== undefined && lane >= 0) updateLaneCount(lane);
    }
  }

  function split(val) {
    return val.split(/\s+/);
  }
  function extractLast(term) {
    return split(term).pop();
  }

  function invertColor(hexTripletColor) {
      let color = hexTripletColor.substring(1);
      color = parseInt(color, 16);
      color = 0xFFFFFF ^ color;
      color = color.toString(16);
      color = ("000000" + color).slice(-6);
      return "#" + color;
  }

  function intToRGB(i) {
    const c = (i & 0x00FFFFFF).toString(16).toUpperCase();
    return "00000".substring(0, 6 - c.length) + c;
  }

  function intToBrightRGB(i) {
    const c = ((~(i & 0x003F3F3F)) & 0x00FFFFFF).toString(16).toUpperCase();
    return "00000".substring(0, 6 - c.length) + c;
  }

//////////////////////REST 2.0 CONNECTION///////////////

  // Normalise a REST 2.0 JSON ticket object into the flat structure
  // used throughout the Kanban JS (same field names as REST 1.0 text parser).

  // RT REST 2.0 returns user/queue fields as objects, e.g.:
  //   {"id": 14, "type": "user", "Name": "john", "_url": "..."}
  // Extract the username/name from whatever shape the object has.
  function extractName(field, fallback) {
    if (!field) return fallback || '';
    if (typeof field === 'string') return field;
    // RT REST 2.0 user objects have a CamelCase 'Name' property
    var name = field.Name || field.name || field.RealName || field.EmailAddress;
    if (name) return name;
    // RT uses id="Nobody" (string) for unassigned tickets — treat string ids as names
    if (field.id !== undefined && field.id !== null) {
      var sid = String(field.id);
      if (sid) return sid;
    }
    return fallback || '';
  }

  function extractNameList(field) {
    if (!field) return '';
    if (typeof field === 'string') return field;
    if (Array.isArray(field)) return field.map(function(r) { return extractName(r); }).join(', ');
    return extractName(field);
  }

  function normalizeTicket(data) {
    if (!data || !data.id) return undefined;

    const ticket = {};
    ticket['id']              = String(data.id);
    ticket['Subject']         = data.Subject        || '';
    ticket['Status']          = data.Status         || '';
    ticket['Priority']        = parseInt(data.Priority)         || 0;
    ticket['InitialPriority'] = parseInt(data.InitialPriority)  || 0;
    ticket['FinalPriority']   = parseInt(data.FinalPriority)    || 0;
    ticket['TimeEstimated']   = parseInt(data.TimeEstimated)    || 0;
    ticket['TimeWorked']      = parseInt(data.TimeWorked)       || 0;
    ticket['TimeLeft']        = parseInt(data.TimeLeft)         || 0;

    ticket['Owner']   = extractName(data.Owner,   'Nobody');
    ticket['Queue']   = extractName(data.Queue,   '');
    ticket['Creator'] = extractName(data.Creator, '');

    // Date fields
    ticket['Created']     = data.Created     || '';
    ticket['Starts']      = data.Starts      || '';
    ticket['Started']     = data.Started     || '';
    ticket['Due']         = data.Due         || '';
    ticket['Resolved']    = data.Resolved    || '';
    ticket['Told']        = data.Told        || '';
    ticket['LastUpdated'] = data.LastUpdated || '';

    ticket['Requestors'] = extractNameList(data.Requestors);
    ticket['Cc']         = extractNameList(data.Cc);
    ticket['AdminCc']    = extractNameList(data.AdminCc);

    calcCustomTicketValues(ticket);
    return ticket;
  }

  // Fields requested from REST 2.0 search / single-ticket endpoints
  const REST2_FIELDS = [
    'id', 'Subject', 'Status', 'Priority', 'InitialPriority', 'FinalPriority',
    'Queue', 'Owner', 'Creator', 'Requestors', 'Cc', 'AdminCc',
    'TimeEstimated', 'TimeWorked', 'TimeLeft',
    'Created', 'Starts', 'Started', 'Due', 'Resolved', 'Told', 'LastUpdated'
  ].join(',');

  const REST2_BASE = "<%RT->Config->Get('WebPath')%>/REST/2.0";

  function merge(id, arr) {
    arr.forEach(function(val) {
      if (!isNaN(val) && val !== "") {
        $.ajax({
          url: REST2_BASE + "/ticket/" + id + "/merge/" + val,
          type: 'PUT',
          success: function() {
            getAndUpdateTicket(id);
            getAndUpdateTicket(val);
          },
          error: function(jqXHR, textStatus) {
            getAndUpdateTicket(id);
            getAndUpdateTicket(val);
            alert("Merge failed: " + textStatus);
          }
        });
      }
    });
  }

  function link(id, rel, arr) {
    arr.forEach(function(val) {
      if (!isNaN(val) && val !== "") {
        $.ajax({
          url: REST2_BASE + "/ticket/" + id + "/links",
          type: 'POST',
          contentType: 'application/json',
          data: JSON.stringify({rel: rel, to: REST2_BASE + "/ticket/" + val}),
          success: function() {},
          error: function(jqXHR, textStatus) {
            alert("Link failed: " + textStatus);
          }
        });
      }
    });
  }

  // Accept a plain JS object of field→value pairs; PUT to REST 2.0.
  function saveTicket(id, fields) {
    (function(ticketId) {
      $.ajax({
        url: REST2_BASE + "/ticket/" + ticketId,
        type: 'PUT',
        contentType: 'application/json',
        data: JSON.stringify(fields),
        success: function(data, status, jqXHR) {
          if (jqXHR.status !== 200) {
            getAndUpdateTicket(ticketId);
          }
        },
        error: function(jqXHR, textStatus) {
          getAndUpdateTicket(ticketId);
          alert("Save failed: " + textStatus);
        }
      });
    })(id);
  }

  function getAndUpdateTicket(id) {
    (function(ticketId) {
      $.ajax({
        url: REST2_BASE + "/ticket/" + ticketId + "?fields=" + REST2_FIELDS,
        type: 'GET',
        dataType: 'json',
        success: function(data) {
          const oldTicket = ticketCache[ticketId];
          const newTicket = normalizeTicket(data);

          if (newTicket === undefined) {
            console.log("ticket " + ticketId + " undefined — deleted");
            deleteTicket(oldTicket);
            return;
          }

          let lane = -1;
          for (let i = 0; i < Columns.length; i++) {
            if (toFunction(getQuery(Columns[i].Query, Columns[i].timeOffSet))(newTicket)) {
              lane = i;
              break;
            }
          }
          newTicket.lane = lane;

          if (lane === -1) {
            deleteTicket(newTicket);
            return;
          }
          if (oldTicket === undefined) {
            console.log("new ticket: " + ticketId);
            updateTicketPosition(newTicket);
            return;
          }
          if (needsUpdate(oldTicket, newTicket)) {
            console.log("ticket updated: " + ticketId);
            updateTicketPosition(newTicket);
          } else {
            ticketCache[ticketId] = newTicket;
          }
        },
        error: function(jqXHR, textStatus) {
          console.log(textStatus);
          alert("Fetch ticket failed: " + textStatus);
        }
      });
    })(id);
  }

  function calcCustomTicketValues(ticket) {
    ticket['Priority'] = parseInt(ticket['Priority']);
    ticket["Color"]        = "#" + intToRGB(parseInt("0x" + md5(ticket["Owner"]).substring(0, 8)));
    ticket["ColorInverse"] = invertColor(ticket["Color"]);
    ticket["ColorBright"]  = "#" + intToBrightRGB(parseInt("0x" + md5(ticket["Queue"]).substring(0, 8)));
    ticket['TimeEstimated'] = parseInt(ticket['TimeEstimated']) || 0;
    ticket['hour']   = Math.floor(ticket['TimeEstimated'] / 60);
    ticket['minute'] = ticket['TimeEstimated'] % 60;
    ticket['Creator'] = String(ticket['Creator']).substring(0, <% $cutCreatorName %>);
  }

  function updateTicketPosition(ticket) {
    calcCustomTicketValues(ticket);
    // Track old lane before removal so we can update its count too
    const oldElem = document.getElementById(ticket['id']);
    const oldLaneUl = oldElem ? oldElem.closest('ul.tasks') : null;
    ticketCache[ticket['id']] = ticket;
    $("#" + ticket['id']).remove();
    const newTicketView = templateTicket(ticket);
    insertTicket(ticket, newTicketView);
    updateLaneCount(ticket.lane);
    // Update old lane count if ticket moved lanes
    if (oldLaneUl && oldLaneUl.id) {
      for (var i = 0; i < Columns.length; i++) {
        if (Columns[i].view && Columns[i].view[0] === oldLaneUl && i !== ticket.lane) {
          updateLaneCount(i);
          break;
        }
      }
    }
  }

  function insertTicket(ticket, newTicketView) {
    const column = Columns[ticket.lane].view;
    if (column.length > 0) {
      const getPriority = function(ticketView) {
        return ticketCache[ticketView.id]['Priority'];
      };
      const index = binarylower(column.children(), getPriority, ticket['Priority'], 0, column.children().length);
      if (index >= column.children().length) {
        column.append(newTicketView);
      } else {
        $(column.children()[index]).before(newTicketView);
      }
    } else {
      column.append(newTicketView);
    }
  }


///////////////////////INIT///////////////////

  function updateLaneCount(laneIndex) {
    var col = Columns[laneIndex];
    if (col && col.view) {
      var count = col.view.children(':not(.drop-area)').length;
      col.view.closest('.card').find('.lane-count').text(count);
    }
  }

  function initTicket(ticket) {
    if (ticketCache[ticket["id"]] === undefined) {
      const column = Columns[ticket.lane].view;
      const newTicketView = templateTicket(ticket);
      ticketCache[ticket['id']] = ticket;
      autocompleteValues.push({label: "#" + ticket['id'] + ': ' + ticket['Subject'], value: ticket['id']});
      if (!testFilter(ticket)) {
        ticketViewCache[ticket['id']] = newTicketView;
        hidden.push(ticket['id']);
      } else {
        column.append(newTicketView);
        updateLaneCount(ticket.lane);
      }
    } else {
      console.log("Only use initTicket during init calls");
    }
  }

  function initColumns() {
    const lanes = $('#lanes');
    for (let i = 0; i < Columns.length; i++) {
      Columns[i]['Id'] = "Column_" + i;
      if (Columns[i].timeOffSet === undefined) Columns[i].timeOffSet = 5;

      lanes.append(templateColumn(Columns[i]));
      const thisLane = $("#" + Columns[i]['Id']);
      Columns[i].view = thisLane;

      (function(LaneObject, thisLane, laneID) {
        thisLane.sortable({
          connectWith: [".wipDrop"],
          placeholder: "drop-area",
          receive: function(event, ui) {
            // ui.item.context was removed in jQuery 3 — use ui.item[0] (native DOM node)
            updatePS(ui.item[0].id, LaneObject, thisLane, '', laneID);
          },
          start: function(event, ui) {
            ui.item.data('start_pos', ui.item.index());
          },
          stop: function(event, ui) {
            const start_pos = ui.item.data('start_pos');
            if (start_pos !== ui.item.index()) {
              if (ui.item[0].parentElement === event.target) {
                updatePS(ui.item[0].id, LaneObject, thisLane, '', laneID);
              }
            }
          },
          activate: function(event, ui) {
            closeAllDropDown();
          },
          scroll: true,
          items: 'li',
          tolerance: "pointer",
          opacity: 0.9,
          over: function(event, ui) {
            // Fix scroll-parent for cross-column drag in jQuery UI 1.12+
            try {
              var si = ui.item.data('ui-sortable') || ui.item.data('sortableItem');
              if (si) {
                si.scrollParent = ui.placeholder.parent();
                si.overflowOffset = ui.placeholder.parent().offset();
              }
            } catch(e) { /* ignore internal jQuery UI API changes */ }
          }
        });
      })(Columns[i], thisLane, i);
    }
  }

  // Load tickets for all lanes using REST 2.0 search endpoint.
  function initView() {
    for (let i = 0; i < Columns.length; i++) {
      const query   = encodeURIComponent(getQuery(Columns[i]['Query'], Columns[i].timeOffSet));
      const url     = REST2_BASE + "/tickets?query=" + query
                      + "&orderby=-Priority"
                      + "&fields=" + encodeURIComponent(REST2_FIELDS)
                      + "&per_page=500";
      (function(lane) {
        $.ajax({
          url: url,
          type: 'GET',
          dataType: 'json',
          success: function(data) {
            const items = data.items || [];
            items.forEach(function(item) {
              // items from the search result already contain the requested fields
              const ticket = normalizeTicket(item);
              if (ticket) {
                ticket.lane = lane;
                initTicket(ticket);
              }
            });
          },
          error: function(jqXHR, textStatus) {
            console.log("initView lane " + lane + " error: " + textStatus);
          }
        });
      })(i);
    }
  }

  let sequence = undefined;

  function initWebsockets() {
    let path = location.protocol.replace('http', 'ws') + "//" + location.hostname;
%if ($myPort != -1){
    path += ":<%$myPort%>";
%}else{
    if (location.port !== "") {
      path += ":" + location.port;
    }
%}
    path += "<%RT->Config->Get('WebPath')%>" + "/websocket";

    const ws = new ReconnectingWebSocket(path);

    ws.onopen = function() {
      console.log('WebSocket connection opened');
      $('#wsIndicator').removeClass('disconnected').addClass('connected').attr('title','WebSocket: connected');
      setInterval(function() {
        ws.send("Keep alive from client");
      }, 200000);
    };

    ws.onmessage = function(msg) {
      const res = JSON.parse(msg.data).updateTicket;

      if (!isNaN(res.sequence)) {
        if (sequence === undefined && res['id'] === undefined) {
          sequence = res.sequence;
        } else if (sequence !== res.sequence) {
          sequence = res.sequence;
          ticketCache = {};
          ticketViewCache = {};
          autocompleteValues = [];
          hidden = [];
          filter = {};

          Columns = config['lanes'];
          $('#lanes').empty();
          initColumns();
          initView();
          $('.filter').trigger('keyup');
        }
      }

      if (res['id'] !== undefined && !isNaN(res.id)) {
        console.log("WebSocket: update ticket " + res.id);
        getAndUpdateTicket(res.id);
        sequence++;
      }
    };

    ws.onclose = function() {
      $('#wsIndicator').removeClass('connected').addClass('disconnected').attr('title','WebSocket: disconnected');
      console.log('WebSocket connection closed');
    };
  }

  // Define configurations before $(document).ready() to avoid TDZ issues
  // when the widget is injected via HTMX into an already-ready document.
  var configurations = {
% foreach(@DisplayedKanbans){
    "<% $_ %>" : `<% $KanbanConfigs{$_}  %>`,
%}
    dummyToAvoidThatLastComma: "empty"
  };

  function kanbanInit() {
    try {
      // Reset all state — safe for repeated calls (HTMX re-init, page restore)
      ticketCache      = {};
      ticketViewCache  = {};
      autocompleteValues = [];
      hidden           = [];
      filter           = {};
      filterWords      = {};
      filters          = [];
      $('#lanes').empty();

      var keys = Object.keys(configurations).filter(function(k) { return k !== 'dummyToAvoidThatLastComma'; });
      if (keys.length === 0) {
        console.error('RT-Kanban: no kanban configurations found');
        return;
      }
      var firstKey = keys[0];
      config = JSON.parse($('<textarea />').html(configurations[firstKey]).text().replace(/(?:\r\n|\r|\n)/g, " "));
      Columns = config['lanes'];
      initColumns();
      initView();
      $('.filter').trigger('keyup');
      initWebsockets();
    } catch(e) {
      console.error('RT-Kanban init error: ' + e.message, e);
    }
  }

  // Support both classic page load and HTMX-boosted navigation (RT 6).
  $(document).ready(function() {
    kanbanInit();
  });
  // If the widget is swapped in via HTMX after initial page load, re-init.
  document.addEventListener('htmx:afterSwap', function(evt) {
    if (evt.target && evt.target.querySelector && evt.target.querySelector('#lanes')) {
      kanbanInit();
    }
  });

  function setKanban(obj) {
    const configuration = obj.options[obj.selectedIndex].value;
    console.log("Switching to kanban: " + configuration);
    config = JSON.parse($('<textarea />').html(configurations[configuration]).text().replace(/(?:\r\n|\r|\n)/g, " "));
    ticketCache = {};
    ticketViewCache = {};
    autocompleteValues = [];
    hidden = [];
    filter = {};

    Columns = config['lanes'];
    $('#lanes').empty();
    initColumns();
    initView();
    $('.filter').trigger('keyup');
  }

  // Expose functions referenced from inline onclick/onchange/onkeyup attributes.
  // These must be on window because HTML attribute handlers are evaluated in
  // global scope, outside the IIFE.
  window.clearFilter      = clearFilter;
  window.setFilter        = setFilter;
  window.setKanban        = setKanban;
  window.toggleFullScreen = toggleFullScreen;
  window.showDropLink     = showDropLink;
  window.showDropMerge    = showDropMerge;
  window.saveTimeMinutes  = saveTimeMinutes;
  window.saveTimeHours    = saveTimeHours;
  window.setOwner         = setOwner;
  window.closeAllDropDown = closeAllDropDown;

}()); // end IIFE — all variables are function-scoped, safe for HTMX re-execution
</script>

  <div id="main" hx-history="false">

    <div id="kanban-toolbar">

      <div class="input-group input-group-sm" style="width:auto">
        <span class="input-group-text">Owner</span>
        <input type="text" class="form-control filter" style="width:90px" onkeyup="setFilter('Owner', this)">
      </div>

      <div class="input-group input-group-sm" style="width:auto">
        <span class="input-group-text">Subject</span>
        <input type="text" class="form-control filter" style="width:110px" onkeyup="setFilter('Subject', this)">
      </div>

      <div class="input-group input-group-sm" style="width:auto">
        <span class="input-group-text">Queue</span>
        <input type="text" class="form-control filter" style="width:90px" onkeyup="setFilter('Queue', this)">
      </div>

      <div class="input-group input-group-sm" style="width:auto">
        <span class="input-group-text">ID</span>
        <input type="text" class="form-control filter" style="width:60px" onkeyup="setFilter('id', this)">
      </div>

      <div class="input-group input-group-sm" style="width:auto">
        <label class="input-group-text" for="kanbanselector">Kanban</label>
        <select id="kanbanselector" class="form-select form-select-sm" onchange="setKanban(this)">
% foreach(@DisplayedKanbans){
          <option value="<% $_ %>"><% $_ %></option>
%}
        </select>
      </div>

      <button class="btn btn-sm btn-outline-secondary" onclick="clearFilter()">&#10005; Filter</button>

      <div class="ms-auto d-flex align-items-center gap-2">
        <span id="wsIndicator" class="ws-dot disconnected" title="WebSocket: disconnected"></span>
        <button class="btn btn-sm btn-outline-secondary" onclick="toggleFullScreen()" title="Toggle fullscreen">&#x26F6;</button>
      </div>

    </div>

    <div id="lanes"></div>

  </div>
</&>

<%INIT>
my $users = RT::Users->new($session{'CurrentUser'});
$users->LimitToPrivileged;


# default configuration
my %KanbanConfigs = (Default => q(
{
  "lanes":[
    {
      "Name": "New Open",
      "Query": "(Status='open' OR Status='new')",
      "Change": {"Status": "open"}
    },
    {
      "Name": "Stalled",
      "Query": "(Status='stalled')",
      "Change": {"Status": "stalled"}
    },
    {
      "Name": "Resolved",
      "Query": "(Status='resolved') AND (LastUpdated > '{{=it.Date}}')",
      "Change": {"Status": "resolved"}
    },
    {
      "Name": "Rejected",
      "Query": "(Status='rejected') AND (LastUpdated > '{{=it.Date}}')",
      "Change": {"Status": "rejected"}
    }
  ]
}));

if (RT->Config->Get('KanbanConfigs')) {
  %KanbanConfigs = RT->Config->Get('KanbanConfigs');
}
my @DisplayedKanbans = keys(%KanbanConfigs);

# Per-installation default
if (RT->Config->Get('KanbanDefault')) {
  @DisplayedKanbans = RT->Config->Get('KanbanDefault');
}

# Per-user override
my $userName   = $session{'CurrentUser'}->Name;
my $userConfig = "Kanban_" . $userName;
if (RT->Config->Get($userConfig)) {
  @DisplayedKanbans = RT->Config->Get($userConfig);
}

my $readOnly = 0;
my $userReadOnly = "KanbanReadOnly_" . $userName;
if (RT->Config->Get($userReadOnly)) {
  $readOnly = RT->Config->Get($userReadOnly);
}

my $myPort = -1;
if (RT->Config->Get("WebsocketPort")) {
  $myPort = RT->Config->Get("WebsocketPort");
}

my $cutCreatorName = 10;
if (RT->Config->Get("cutCreatorName")) {
  $cutCreatorName = RT->Config->Get("cutCreatorName");
}

</%INIT>
<%ARGS>
$Name => 'Users'

</%ARGS>
